# 🔐 Configuración de Entorno - TortillApuestas
# Copia este archivo a .env y personaliza los valores

# ═══════════════════════════════════════════════════════════════
# 🗄️ BASE DE DATOS (SQLite)
# ═══════════════════════════════════════════════════════════════
# Ruta de la base de datos SQLite
# Para desarrollo local: ./tortilla_apuestas_dev.db (por defecto)
# Para Docker: /app/data/tortilla_apuestas_dev.db (configurado automáticamente)
DB_PATH=./tortilla_apuestas_dev.db

# ═══════════════════════════════════════════════════════════════
# 🔑 SEGURIDAD - JWT
# ═══════════════════════════════════════════════════════════════
# Genera una clave segura: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-please-1234567890abc

# ═══════════════════════════════════════════════════════════════
# 🌍 ENTORNO
# ═══════════════════════════════════════════════════════════════
ENVIRONMENT=production

# ═══════════════════════════════════════════════════════════════
# 🌐 URL DEL FRONTEND (para CORS)
# ═══════════════════════════════════════════════════════════════
FRONTEND_URL=https://tortilla.rubiocloud.duckdns.org
